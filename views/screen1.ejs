<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PolyChat - Explore</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <div class="app-container">
        <div class="sidebar" id="sidebar">
            <div class="sidebar-top">
                <div class="logo">
                    <svg class="icon-navy" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round"
                            d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
                    </svg>
                    PolyChat
                </div>
                <button class="new-chat-btn"> New Chat</button>
            </div>
            <nav class="chat-history">
                <div class="history-item">Quantum computing encrypt...ewiwrjhlwerik</div>
                <div class="history-item">React performance optimizat...</div>
                <div class="history-item">Q3 Marketing Strategy</div>
                <div class="history-item">Python async best practices</div>
                <div class="history-item">Design system components</div>
            </nav>
            <div class="sidebar-bottom">
                <div class="footer-link">
                    <svg class="icon-small" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path
                            d="M10.343 3.94c.09-.542.56-.94 1.11-.94h1.094c.55 0 1.02.398 1.11.94l.149.894c.07.424.384.764.78.93.398.164.855.142 1.205-.108l.737-.527a1.125 1.125 0 011.45.12l.773.774a1.125 1.125 0 01.12 1.45l-.527.737c-.25.35-.272.806-.107 1.204.165.397.505.71.93.78l.894.15c.542.09.94.56.94 1.109v1.094c0 .55-.398 1.02-.94 1.11l-.894.149c-.424.07-.764.383-.93.78-.165.398-.143.854.107 1.204l.527.738a1.125 1.125 0 01-.12 1.45l-.773.773a1.125 1.125 0 01-1.45.12l-.737-.527c-.35-.25-.806-.272-1.203-.107-.397.165-.71.505-.781.929l-.149.894c-.09.542-.56.94-1.11.94h-1.094c-.55 0-1.019-.398-1.11-.94l-.148-.894c-.071-.424-.384-.764-.781-.93-.398-.164-.854-.142-1.204.108l-.738.527a1.125 1.125 0 01-1.45-.12l-.773-.774a1.125 1.125 0 01-.12-1.45l.527-.737c.25-.35.273-.806.108-1.204-.165-.397-.505-.71-.93-.78l-.894-.15c-.542-.09-.94-.56-.94-1.109v-1.094c0-.55.398-1.02.94-1.11l.894-.149c.424-.07.765-.383.93-.78.165-.398.143-.854-.108-1.204l-.526-.738a1.125 1.125 0 01.12-1.45l.773-.773a1.125 1.125 0 011.45-.12l.737.527c.35.25.807.272 1.204.107.397-.165.71-.505.78-.929l.15-.894z" />
                        <circle cx="12" cy="12" r="3" />
                    </svg>
                    Settings
                </div>
                <div class="user-card">
                    <div class="user-avatar">AC</div>
                    <div class="user-meta">
                        <div class="user-name">Alex Chen</div>
                        <div class="user-plan">Pro Plan</div>
                    </div>
                </div>
            </div>
        </div>

        <main class="content-area landing-view">
            <button class="sidebar-toggle" id="sidebarToggle">
                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                </svg>
            </button>
            <button class="notification-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="1.5">
                    <path
                        d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
                </svg></button>

            <div class="hero-section">
                <h1>Where do you want to explore today?</h1>
                <p class="subtitle">Query multiple advanced models simultaneously.</p>
                <form action="/polychat/new" method="POST">
                    <input type="hidden" id="selectedModelInput" name="model" value="gemini-2.5-flash">
                    <div class="model-tabs">

                        <div class="tab" data-model="gpt-4o">GPT-4o</div>

                        <div class="tab" data-model="cohere">Cohere </div>
                        <div class="tab active" data-model="gemini-2.5-flash">Gemini 2.5 Flash</div>
                        <div class="tab auto-tab">
                            <svg class="icon-tiny" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path
                                    d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
                            </svg>
                            Auto
                        </div>
                    </div>

                    <div class="main-search-wrapper">

                        <div class="main-search-bar">
                            <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                <circle cx="11" cy="11" r="8" />
                                <path d="m21 21-4.3-4.3" />
                            </svg>
                            <input type="text" placeholder="Ask anything..." name="message">
                            <div class="search-actions">
                                <svg class="icon-small hov" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                    <path
                                        d="M18.375 12.739l-7.693 7.693a4.5 4.5 0 01-6.364-6.364l10.94-10.94A3 3 0 1119.5 7.372L8.552 18.32a1.5 1.5 0 11-2.121-2.121l10.592-10.592" />
                                </svg>
                                <svg class="icon-small hov" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                    <path
                                        d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />
                                </svg>
                                <button type="submit" class="send-button"><svg class="icon-white" viewBox="0 0 24 24"
                                        fill="none" stroke="currentColor">
                                        <path d="M4.5 10.5L12 3m0 0l7.5 7.5M12 3v18" />
                                    </svg></button>
                            </div>
                        </div>
                    </div>
                </form>

                <div class="action-chips">
                    <div class="chip"><svg class="icon-tiny" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path
                                d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
                        </svg> Summarize</div>
                    <div class="chip"><svg class="icon-tiny" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
                        </svg> Code</div>
                    <div class="chip"><svg class="icon-tiny" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path
                                d="M12 18v3m0 0h.01m-4.66-2.34-.35.35m0 0h.01m10-.35.35.35m0 0h.01M12 3c4.97 0 9 4.03 9 9s-4.03 9-9 9-9-4.03-9-9 4.03-9 9-9z" />
                        </svg> Brainstorm</div>
                    <div class="chip"><svg class="icon-tiny" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path
                                d="M3 13.125C3 12.504 3.504 12 4.125 12h.75c.621 0 1.125.504 1.125 1.125v6.75C6 20.496 5.496 21 4.875 21h-.75A1.875 1.875 0 013 19.125v-6zM9 9.375C9 8.754 9.504 8.25 10.125 8.25h.75c.621 0 1.125.504 1.125 1.125v10.5c0 .621-.504 1.125-1.125 1.125h-.75A1.875 1.875 0 019 19.125V9.375zM15 4.875c0-.621.504-1.125 1.125-1.125h.75c.621 0 1.125.504 1.125 1.125V21h-3V4.875z" />
                        </svg> Analyze Data</div>
                </div>

            </div>


            <footer class="landing-footer">
                <nav>
                    <a href="#">TERMS</a>
                    <a href="#">PRIVACY</a>
                    <a href="#">SYSTEM STATUS <span class="status-dot"></span></a>
                </nav>
            </footer>
            </mai>
    </div>
    <script src="/script.js"></script>
</body>

</html>