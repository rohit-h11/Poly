                    Thinking.....
                </article>

                <section class="footer-actions">
                    <div class="feedback-row">
                        <div class="vote-group">
                            <button class="action-btn">Helpful</button>
                            <button class="action-btn">Dislike</button>
                        </div>
                        <button class="action-btn share-btn">
                            <svg class="icon-tiny" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185zm0 12.814a2.25 2.25 0 103.933 2.185 2.25 2.25 0 00-3.933-2.185z" /></svg>
                            Share
                        </button>
                    </div>
                    
                    <!-- <div class="related-section">
                        <h4>Related Questions</h4>
                        <div class="related-grid">
                            <div class="q-chip">aweoe  fnskdf fkfasd </div>
                            <div class="q-chip">How aweoe  fnskdf fkfasd </div>
                        </div>
                    </div> -->
                </section>
            </div>

            <form class="search-container" id="chat-form">
                <div class="search-bar">
                    <div class="model-tag">
                        <%= model%>
                        <svg class="icon-tiny" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
                    </div>
                    <input type="text" placeholder="Ask anything about your data..." id="bottom-input">
                    <div class="input-tools">
                        <svg class="icon-small" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18.375 12.739l-7.693 7.693a4.5 4.5 0 01-6.364-6.364l10.94-10.94A3 3 0 1119.5 7.372L8.552 18.32a1.5 1.5 0 11-2.121-2.121l10.592-10.592" /></svg>
                        <svg class="icon-small" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" /></svg>
                        <button class="send-button">
                            <svg class="icon-white" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5L12 3m0 0l7.5 7.5M12 3v18" /></svg>
                        </button>
                    </div>
                </div>
            </form>
        </main>
    </div>
    <script src="/script.js"></script>
</body>
</html>